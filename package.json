{
  "name": "reindustrialize",
  "version": "0.7.0-alpha",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10.24 <11"
  },
  "scripts": {
    "security:git": "node scripts/validate-git-release.mjs",
    "game:doctor": "node scripts/game-dev-doctor.mjs",
    "game:generate": "python scripts/build_level_viewer_v4.py",
    "game:smoke": "python scripts/build_level_viewer_v4.py && python tests/e2e_startup_performance.py && python tests/e2e_save_pause_settings.py && python tests/e2e_gamepad.py && python tests/e2e_phone_controller.py",
    "game:hooks:install": "git config core.hooksPath .githooks",
    "agents:review:check": "node scripts/validate-review-agents.mjs",
    "audio:check": "node scripts/validate-audio-production.mjs",
    "visuals:check": "node scripts/validate-visual-coverage.mjs",
    "realism:check": "node scripts/validate-manufacturing-realism.mjs",
    "campaign:check": "node scripts/validate-full-campaign.mjs",
    "campaign:check:1.0": "node scripts/validate-full-campaign.mjs --assert-1.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "tsx --test tests/*.test.ts",
    "game:verify": "pnpm game:doctor && pnpm typecheck && pnpm test:unit && pnpm validate:content && pnpm agents:review:check && pnpm release:gate && pnpm backend:check && pnpm bug-bounty:baseline && pnpm security:git",
    "game:verify:full": "pnpm game:verify && pnpm test:e2e && pnpm cloudflare:build && pnpm audit --prod --audit-level high",
    "cloudflare:dns:audit": "node scripts/configure-cloudflare-domain.mjs",
    "cloudflare:dns:apply": "node scripts/configure-cloudflare-domain.mjs --apply",
    "bug-bounty:baseline": "node scripts/bug-bounty-baseline.mjs",
    "cloudflare:build": "python scripts/build_level_viewer_v4.py && pnpm release:gate && pnpm seo:check && node scripts/build-cloudflare-site.mjs",
    "cloudflare:dev": "pnpm cloudflare:build && wrangler dev",
    "cloudflare:deploy": "pnpm cloudflare:build && wrangler deploy",
    "build": "pnpm typecheck && pnpm release:gate && pnpm cloudflare:build",
    "release:gate": "node scripts/validate-release-gate.mjs && node scripts/validate-equipment-sfx.mjs && node scripts/validate-customer-contracts.mjs && node scripts/validate-visual-storybook.mjs && node scripts/validate-storybook-versioning.mjs && node scripts/validate-workforce-and-founders.mjs && node scripts/validate-privacy-analytics.mjs",
    "workforce:check": "node scripts/validate-workforce-and-founders.mjs",
    "bot:test:workforce": "python tests/e2e_workforce_conversations.py",
    "facilities:check": "python tests/e2e_facility_amenities.py",
    "privacy:check": "node scripts/validate-privacy-analytics.mjs",
    "test:e2e:mobile": "python tests/e2e_mobile_game.py",
    "roadmap:check": "node scripts/validate-release-roadmap.mjs",
    "bundle:game": "python scripts/build_level_viewer_v4.py && pnpm release:gate && pnpm test:e2e:run && powershell.exe -ExecutionPolicy Bypass -File scripts/build-game-bundle.ps1",
    "assets:check": "node scripts/validate-runtime-assets.mjs",
    "validate:content": "tsx scripts/validate-content.ts",
    "validate:scenes": "python scripts/validate-player-scenes.py",
    "story:check": "node scripts/validate-story-production.mjs",
    "tour:check": "node scripts/validate-shop-tour.mjs",
    "tasks:check": "node scripts/validate-production-task-tutorials.mjs",
    "backend:check": "node scripts/validate-backend-readiness.mjs",
    "amazon:luna:check": "node scripts/validate-amazon-luna-release.mjs",
    "release:identity": "pnpm cloudflare:build && node -e \"const r=require('./cloudflare-dist/release.json'); console.log(r.version, r.sourceRevision, r.builtAt)\"",
    "llm:check": "node scripts/validate-llm-mentor.mjs",
    "promo:check": "node scripts/validate-promo-videos.mjs",
    "promo:check:voice": "node scripts/validate-promo-voiceovers.mjs",
    "promo:check:v2-media": "python scripts/validate-v2-video-media.py",
    "promo:check:current-media": "python scripts/validate-v2-video-media.py",
    "promo:check:real-gameplay": "node scripts/validate-real-gameplay-demos.mjs",
    "hero:check:v7": "node scripts/validate-hero-campaign-v7.mjs",
    "hero:check:v8": "node scripts/validate-hero-campaign-v8.mjs",
    "seo:check": "node scripts/validate-public-seo.mjs",
    "videos:test:web": "python tests/e2e_video_library.py",
    "audio:plan": "node scripts/generate-elevenlabs-audio.mjs --dry-run",
    "audio:generate": "node scripts/generate-elevenlabs-audio.mjs",
    "demo:studio": "remotion studio demo/remotion/src/index.ts --public-dir=demo/remotion/public",
    "demo:render": "remotion render demo/remotion/src/index.ts ReindustrializeDemo tmp/demo/render/reindustrialize-demo.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:vertical": "remotion render demo/remotion/src/index.ts ReindustrializeVerticalShort videos/vertical-shorts/reindustrialize-founder-to-factory-vertical.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:square": "remotion render demo/remotion/src/index.ts ReindustrializeSquareSocial videos/square-social/reindustrialize-founder-to-factory-square.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:launch": "remotion render demo/remotion/src/index.ts LaunchTrailer30 videos/horizontal-demos/reindustrialize-launch-trailer-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:gameplay": "remotion render demo/remotion/src/index.ts GameplayFeatureReel45 videos/gameplay-longform/reindustrialize-gameplay-features-45s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:founders": "remotion render demo/remotion/src/index.ts FounderSelectionShort20 videos/vertical-shorts/reindustrialize-founder-selection-20s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:zach": "remotion render demo/remotion/src/index.ts ZachMentorPromo30 videos/vertical-shorts/reindustrialize-zach-mentor-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:growth": "remotion render demo/remotion/src/index.ts BusinessGrowthPromo30 videos/square-social/reindustrialize-business-growth-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-launch": "remotion render demo/remotion/src/index.ts PlayerReviewLaunch30 videos/horizontal-demos/reindustrialize-player-review-launch-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-gameplay": "remotion render demo/remotion/src/index.ts PlayerReviewGameplay30 videos/vertical-shorts/reindustrialize-player-review-gameplay-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-growth": "remotion render demo/remotion/src/index.ts PlayerReviewGrowth30 videos/square-social/reindustrialize-player-review-growth-30s.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:v2": "remotion render demo/remotion/src/index.ts ReindustrializeDemoV2 videos/horizontal-demos/reindustrialize-founder-to-factory-1080p-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:vertical:v2": "remotion render demo/remotion/src/index.ts ReindustrializeVerticalShortV2 videos/vertical-shorts/reindustrialize-founder-to-factory-vertical-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:square:v2": "remotion render demo/remotion/src/index.ts ReindustrializeSquareSocialV2 videos/square-social/reindustrialize-founder-to-factory-square-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:launch:v2": "remotion render demo/remotion/src/index.ts LaunchTrailer30V2 videos/horizontal-demos/reindustrialize-launch-trailer-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:gameplay:v2": "remotion render demo/remotion/src/index.ts GameplayFeatureReel45V2 videos/gameplay-longform/reindustrialize-gameplay-features-45s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:founders:v2": "remotion render demo/remotion/src/index.ts FounderSelectionShort20V2 videos/vertical-shorts/reindustrialize-founder-selection-20s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:zach:v2": "remotion render demo/remotion/src/index.ts ZachMentorPromo30V2 videos/vertical-shorts/reindustrialize-zach-mentor-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:growth:v2": "remotion render demo/remotion/src/index.ts BusinessGrowthPromo30V2 videos/square-social/reindustrialize-business-growth-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-launch:v2": "remotion render demo/remotion/src/index.ts PlayerReviewLaunch30V2 videos/horizontal-demos/reindustrialize-player-review-launch-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-gameplay:v2": "remotion render demo/remotion/src/index.ts PlayerReviewGameplay30V2 videos/vertical-shorts/reindustrialize-player-review-gameplay-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "promo:render:player-growth:v2": "remotion render demo/remotion/src/index.ts PlayerReviewGrowth30V2 videos/square-social/reindustrialize-player-review-growth-30s-v2.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "media:render:v2": "pnpm demo:render:v2 && pnpm demo:render:vertical:v2 && pnpm demo:render:square:v2 && pnpm promo:render:launch:v2 && pnpm promo:render:gameplay:v2 && pnpm promo:render:founders:v2 && pnpm promo:render:zach:v2 && pnpm promo:render:growth:v2 && pnpm promo:render:player-launch:v2 && pnpm promo:render:player-gameplay:v2 && pnpm promo:render:player-growth:v2",
    "gameplay:record:full:v3": "python scripts/record-full-gameplay.py",
    "gameplay:render:full:v3": "remotion render demo/remotion/src/index.ts FullGameplayGarageToJobShopV3 videos/gameplay-longform/reindustrialize-full-gameplay-garage-to-job-shop-v3.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:real-horizontal:v4": "remotion render demo/remotion/src/index.ts RealGameplayDemoHorizontalV4 videos/horizontal-demos/reindustrialize-real-gameplay-demo-60s-v4.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:real-feature:v4": "remotion render demo/remotion/src/index.ts RealGameplayFeature45V4 videos/gameplay-longform/reindustrialize-real-gameplay-features-45s-v4.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:real-vertical:v4": "remotion render demo/remotion/src/index.ts RealGameplayVerticalShortV4 videos/vertical-shorts/reindustrialize-real-gameplay-short-30s-v4.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:real-square:v4": "remotion render demo/remotion/src/index.ts RealGameplaySquareV4 videos/square-social/reindustrialize-real-gameplay-square-30s-v4.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "demo:render:real-slate:v4": "pnpm demo:render:real-horizontal:v4 && pnpm demo:render:real-feature:v4 && pnpm demo:render:real-vertical:v4 && pnpm demo:render:real-square:v4",
    "bot:play:v5": "python scripts/human-gameplay-bot.py --pace fast",
    "bot:record:v5": "python scripts/human-gameplay-bot.py --pace record",
    "bot:render:full:v5": "remotion render demo/remotion/src/index.ts HumanBotFullGameplayV5 videos/gameplay-longform/reindustrialize-human-bot-full-gameplay-v5.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "bot:render:demo:v5": "remotion render demo/remotion/src/index.ts HumanBotDemoHorizontalV5 videos/horizontal-demos/reindustrialize-human-bot-demo-60s-v5.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "hero:render:v7": "remotion render demo/remotion/src/index.ts HeroCampaignV7 apps/playreind-landing/public/media/gameplay-hero-v7.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "hero:render:v8": "remotion render demo/remotion/src/index.ts HeroCampaignV8 apps/playreind-landing/public/media/gameplay-hero-v8.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "bot:render:feature:v5": "remotion render demo/remotion/src/index.ts HumanBotFeature45V5 videos/gameplay-longform/reindustrialize-human-bot-feature-45s-v5.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "bot:render:vertical:v5": "remotion render demo/remotion/src/index.ts HumanBotVerticalShortV5 videos/vertical-shorts/reindustrialize-human-bot-short-30s-v5.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "bot:render:square:v5": "remotion render demo/remotion/src/index.ts HumanBotSquareV5 videos/square-social/reindustrialize-human-bot-square-30s-v5.mp4 --codec=h264 --public-dir=demo/remotion/public",
    "bot:render:slate:v5": "pnpm bot:render:demo:v5 && pnpm bot:render:feature:v5 && pnpm bot:render:vertical:v5 && pnpm bot:render:square:v5",
    "bot:check:v5": "node scripts/validate-human-gameplay-bot.mjs",
    "storybook:build": "python scripts/build-visual-storybook.py",
    "storybook:export": "python scripts/export-visual-storybook.py",
    "storybook:check": "node scripts/validate-visual-storybook.mjs",
    "storybook:check:version": "node scripts/validate-storybook-versioning.mjs",
    "storybook:release": "pnpm storybook:build && pnpm storybook:export && pnpm storybook:check",
    "test:e2e": "pnpm release:gate && pnpm test:e2e:run",
    "test:e2e:run": "python tests/e2e_character_story_variants.py && python tests/e2e_zach_mentor.py && python tests/e2e_chapter_one_story.py && python tests/e2e_shop_tour.py && python tests/e2e_task_tutorials.py && python tests/e2e_opening.py && python tests/e2e_hiring.py && python tests/e2e_material_ordering.py && python tests/e2e_movement_usability.py && python tests/e2e_topdown_task_loop.py && python tests/e2e_campaign_roadmap.py && python tests/e2e_gamepad.py && python tests/e2e_phone_controller.py && python tests/e2e_title_control_selection.py && python tests/e2e_young_learner.py && python tests/e2e_young_learner_first_job.py && python tests/e2e_equipment_market.py && python tests/e2e_equipment_operating_profiles.py && python tests/e2e_robotics_progression.py && python tests/e2e_maintenance_constraints.py && python tests/e2e_equipment_damage_states.py && python tests/e2e_facility_amenities.py && python tests/e2e_mobile_game.py && python tests/e2e_startup_performance.py && python tests/e2e_save_pause_settings.py && python tests/e2e_equipment_audio_sequence.py && python tests/e2e_customer_contracts.py && python tests/e2e_ambient_audio.py"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.491",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.491",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.34.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
