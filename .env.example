# Copy these values into your shell or an untracked .env.local file. Never commit live secrets.
ELEVENLABS_API_KEY=
ELEVENLABS_ZACH_VOICE_ID=
# Must be exactly "yes" after Zach has signed docs/ZACH_VOICE_CONSENT.md.
ZACH_VOICE_CONSENT_CONFIRMED=no
# Optional. Global endpoint is the default; use an approved residency endpoint when applicable.
ELEVENLABS_API_BASE=https://api.elevenlabs.io

# Cloud accounts/saves are deliberately disabled until the release gate is approved.
PUBLIC_BACKEND_MODE=disabled
PUBLIC_CLOUD_FEATURES_ENABLED=false
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Non-secret project/auth metadata for later setup. Keep cloud features false until release approval.
SUPABASE_PROJECT_REF=
SUPABASE_AUTH_SITE_URL=https://playreind.com
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS=http://localhost:8788,https://www.playreind.com
# CLI/Management API only. Never prefix with PUBLIC_ and never ship it to a browser bundle.
SUPABASE_ACCESS_TOKEN=
# Privileged Supabase secret/service-role/database values belong only in the provider's encrypted
# server secret store. Never add their variable names or values to browser builds or this template.

# Future Zach mentor LLM. Disabled until security, quality, privacy, and cost gates pass.
LLM_MENTOR_ENABLED=false
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openrouter/free
LLM_MAX_REQUESTS_PER_MINUTE=10
