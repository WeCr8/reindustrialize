    "graceRule": "Every newly unlocked recurring cost or performance metric has a visible tutorial and at least the declared grace period before penalties.",
    "chapter1ForbiddenGates": ["OEE", "scheduled utilization", "payroll coverage", "accounts receivable", "manager span", "preventive-maintenance compliance", "facility commissioning score"],
