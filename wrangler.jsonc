{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "reindustrialize",
  "compatibility_date": "2026-07-19",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./cloudflare-dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "playreind.com", "custom_domain": true },
    { "pattern": "www.playreind.com", "custom_domain": true }
  ]
}
